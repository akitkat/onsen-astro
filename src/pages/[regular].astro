---
import Base from "@layouts/Base.astro";
import Default from "@layouts/Default.astro";
import PostSingle from "@layouts/PostSingle.astro";
import { getSinglePage } from "@lib/contentParser.astro";
import { getPageUrl } from "@lib/utils/siteUrl";
import { getImage } from "astro:assets";

const siteBaseUrl = import.meta.env.SITE_BASE_URL;
const siteTitle = import.meta.env.SITE_TITLE;
const getPosts = await getSinglePage("posts");
const postsSlug = getPosts.map((item) => item.id);

export async function getStaticPaths() {
  const posts = await getSinglePage("posts");
  const pages = await getSinglePage("pages");
  const allPages = [...pages, ...posts];

  const paths = allPages.map((page) => ({
    params: {
      regular: page.id,
    },
    props: { page },
  }));
  return paths;
}

const { page } = Astro.props;
const { title, meta_title, description, image, date, tags } = page.data;
const isPost = postsSlug.includes(page.id);
const articleUrl = getPageUrl(`/${page.id}/`, siteBaseUrl);

const jsonLd: object[] = [];

if (isPost) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "Article",
    headline: title,
    url: articleUrl,
    mainEntityOfPage: articleUrl,
    datePublished: date,
    dateModified: date,
    image: image,
    author: {
      "@type": "Person",
      name: "akitkat",
    },
    publisher: {
      "@type": "Organization",
      name: siteTitle,
      logo: {
        "@type": "ImageObject",
        url: `${siteBaseUrl}/icons/icon-144x144.png`,
      },
    },
  });

  const breadcrumbItems = [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: siteBaseUrl,
    },
  ];

  if (tags?.[0]) {
    breadcrumbItems.push({
      "@type": "ListItem",
      position: 2,
      name: tags[0],
      item: `${siteBaseUrl}/tags/${tags[0]}/`,
    });
  }

  breadcrumbItems.push({
    "@type": "ListItem",
    position: breadcrumbItems.length + 1,
    name: title,
    item: articleUrl,
  });

  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: breadcrumbItems,
  });
}

let preloadImage: string | undefined;
if (isPost && image) {
  const optimized = await getImage({ src: image, width: 1000, height: 500 });
  preloadImage = optimized.src;
}
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
  json_ld={jsonLd.length > 0 ? jsonLd : undefined}
  preloadImage={preloadImage}
  ogType={isPost ? "article" : "website"}
  publishedTime={isPost && date ? date : undefined}
>
  {isPost ? <PostSingle post={page} /> : <Default data={page} />}
</Base>
